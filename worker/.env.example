# Supabase (required)
SUPABASE_URL=https://xxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Worker identity & concurrency
WORKER_HOST=                       # leave blank to use os.uname().nodename
WORKER_MAX_CONCURRENT_JOBS=1       # tune per machine (1 for laptop, 3+ for big rig)

# Disk management (used by Session B; stub logs intended values)
WORKER_TEMP_DIR=/tmp/cusa_highlights
KEEP_SOURCE_ON_SUCCESS=false
KEEP_SOURCE_ON_FAILURE_HOURS=24
MAX_TEMP_DISK_GB=100

# Polling cadence
POLL_INTERVAL_SECONDS=30
HEARTBEAT_INTERVAL_SECONDS=30
STALE_SWEEP_INTERVAL_MINUTES=5
