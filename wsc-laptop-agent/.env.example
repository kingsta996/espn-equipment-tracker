# Copy to .env on each laptop and fill in the values below.
# Run with:  set -a; source .env; set +a; python3 wsc_laptop_agent.py

# This laptop's identity. One of: LAPTOP-A, LAPTOP-B
LAPTOP_ID=LAPTOP-A

# CUSA Supabase project URL + anon key.
# Same values as window.SUPABASE_URL in config.js.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Optional — which browser to open. Defaults to Google Chrome.
# BROWSER_APP=Google Chrome

# Optional — poll cadence in seconds. Defaults to 30.
# POLL_INTERVAL_S=30

# Optional — fire this many seconds ahead of trigger_at. Default 5.
# LEAD_TIME_S=5

# Optional — send 'f' to Chrome after launch to fullscreen ESPN's player.
# Requires Accessibility permission for Terminal (or whatever runs the
# agent) in System Settings → Privacy & Security → Accessibility.
# FULLSCREEN_AFTER_LAUNCH=true

# Optional — seconds to wait after opening URL before sending 'f' so the
# ESPN player has time to load. Default 8.
# FULLSCREEN_DELAY_S=8
