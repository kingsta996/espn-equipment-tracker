# Copy to .env on each laptop, fill in the values, then:
#   set -a; source .env; set +a; python3 wsc_laptop_agent.py

# This laptop's identity. Must be one of: LAPTOP-A, LAPTOP-B
LAPTOP_ID=LAPTOP-A

# CUSA Supabase project URL + anon key (same values as window.SUPABASE_URL
# in config.js — anon-key writes are allowed by the wsc_laptop_dispatches
# RLS policy).
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Optional — which browser to open. Defaults to Google Chrome.
# BROWSER_APP=Google Chrome

# Optional — tune the poll cadence (seconds). Defaults to 30.
# POLL_INTERVAL_S=30

# Optional — how far ahead of trigger_at to fire (seconds). Defaults to 5.
# LEAD_TIME_S=5
